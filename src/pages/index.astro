    <!-- Search -->
    <section class="mb-12">
      <div class="relative max-w-2xl mx-auto">
        <div class="absolute inset-y-0 left-5 flex items-center pointer-events-none">
          <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        <input
          id="search-input"
          type="text"
          placeholder="Search repositories by name or mood..."
          class="w-full pl-14 pr-6 py-4 bg-secondary/60 backdrop-blur-xl border border-white/10 rounded-2xl text-white placeholder-gray-500 focus:outline-none focus:border-purple-500/50 focus:ring-2 focus:ring-purple-500/20 transition-all text-lg shadow-lg shadow-black/20"
        />
        <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
          <kbd class="hidden sm:inline-flex items-center gap-1 px-2.5 py-1.5 bg-white/5 border border-white/10 rounded-lg text-xs text-gray-500">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 16 16"><path d="M.293.293a1 1 0 011.414 0L8 6.583 14.293.293a1 1 0 111.414 1.414L9.414 8l6.293 6.293a1 1 0 01-1.414 1.414L8 9.414l-6.293 6.293a1 1 0 01-1.414-1.414L6.586 8 .293 1.707a1 1 0 010-1.414z"/></svg>
            Search
          </kbd>
        </div>
      </div>
    </section>

    <!-- Error State -->
    {fetchError && (
      <section class="py-12 text-center">
        <h3 class="text-xl font-semibold text-white mb-2">Failed to load repositories</h3>
        <p class="text-gray-400 mb-6">{fetchError}</p>
        <button onclick="window.location.reload()" class="px-6 py-3 bg-red-600 hover:bg-red-500 text-white font-semibold rounded-xl">Retry</button>
      </section>
    )}

    <!-- No Results -->
    {!fetchError && repos.length === 0 && (
      <section class="py-12 text-center">
        <h3 class="text-xl font-semibold text-white mb-2">No repositories found</h3>
        <p class="text-gray-400 mb-6">This is embarrassing.</p>
      </section>
    )}

    <!-- Repo Grid -->
    {!fetchError && repos.length > 0 && (
      <section id="repo-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 animate-fade-in">
        {repos.map((repo) => {
          const sentiment = analyzeSentiment(repo);
          const moodClass = getMoodClass(sentiment);
          const sentimentColor = getSentimentColor(sentiment);

          return (
            <article
              class={`group relative bg-card hover:bg-card-hover rounded-3xl border border-white/[0.08] hover:border-purple-500/30 p-6 transition-all duration-500 hover:scale-[1.02] hover:shadow-2xl hover:shadow-purple-500/10 cursor-pointer card-shine overflow-hidden ${moodClass}`}
              data-repo-name={repo.name}
              data-sentiment={sentiment}
              tabindex="0"
            >
              <!-- Gradient overlay on hover -->
              <div class="absolute inset-0 bg-gradient-to-br from-purple-500/[0.03] to-pink-500/[0.03] opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

              <!-- Top badges -->
              <div class="flex items-center gap-2 mb-4 relative">
                <span class={`inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-xl border transition-colors ${sentimentColor.replace('text-', 'bg-').replace('400', '500/10')} ${sentimentColor} border-white/10`}>
                  {sentiment}
                </span>
                <span class="px-3 py-1.5 bg-green-500/10 text-green-400 text-xs font-medium rounded-xl border border-green-500/20">
                  ✨ Certified Slop
                </span>
              </div>

              <!-- Repo name -->
              <h3 class="font-bold text-xl text-purple-300 group-hover:text-purple-200 mb-3 transition-colors line-clamp-1">{repo.name}</h3>

              <!-- Description -->
              <p class="text-gray-400 text-sm mb-4 min-h-[3rem] line-clamp-2 leading-relaxed">{repo.description || 'No description provided. Just pure slop.'}</p>

              <!-- Topics -->
              {repo.topics && repo.topics.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-4">
                  {repo.topics.slice(0, 4).map((topic) => (
                    <span class="px-2.5 py-1 bg-purple-500/10 text-purple-300 text-xs rounded-lg border border-purple-500/20 hover:border-purple-500/40 transition-colors">
                      #{topic}
                    </span>
                  ))}
                </div>
              )}

              <!-- Bottom meta -->
              <div class="flex flex-wrap items-center gap-3 text-xs text-gray-500 pt-4 border-t border-white/[0.06]">
                {repo.language && (
                  <span class="flex items-center gap-1.5">
                    <span class="w-2.5 h-2.5 rounded-full bg-gradient-to-r from-blue-400 to-cyan-400 shadow-sm"></span>
                    <span class="font-medium">{repo.language}</span>
                  </span>
                )}
                <span class="flex items-center gap-1.5" title="Stars">
                  <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 16 16"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/></svg>
                  {formatNumber(repo.stargazers_count)}
                </span>
                <span class="flex items-center gap-1.5" title="Forks">
                  <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 16 16"><path d="M5 3.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm0 2.122a2.25 2.25 0 10-1.5 0v.878A2.25 2.25 0 005.75 8.5h1.5v2.128a2.251 2.251 0 101.5 0V8.5h1.5a2.25 2.25 0 002.25-2.25v-.878a2.25 2.25 0 10-1.5 0v.878a.75.75 0 01-.75.75h-4.5A.75.75 0 015 6.25v-.878zm3.75 7.378a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm3-8.75a.75.75 0 100-1.5.75.75 0 000 1.5z"/></svg>
                  {formatNumber(repo.forks_count)}
                </span>
                <span class="ml-auto flex items-center gap-1.5" title="Last updated">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 16 16"><path d="M8 3.5a.5.5 0 00-1 0V9a.5.5 0 00.252.434l3.5 2a.5.5 0 00.496-.868L8 8.71V3.5z"/><path d="M8 16A8 8 0 108 0a8 8 0 000 16zm7-8A7 7 0 111 8a7 7 0 0114 0z"/></svg>
                  {getRelativeTime(repo.updated_at)}
                </span>
              </div>
            </article>
          );
        })}
      </section>
    )}
  </main>

  <!-- Achievement Modal -->
  <div id="achievement-modal" class="hidden fixed inset-0 z-50 overflow-y-auto" role="dialog" aria-modal="true" aria-labelledby="achievements-title">
    <div class="fixed inset-0 bg-black/80 backdrop-blur-sm transition-opacity animate-fade-in"></div>
    <div class="relative min-h-screen flex items-center justify-center p-4">
      <div class="relative bg-card rounded-3xl border border-white/10 shadow-2xl max-w-2xl w-full max-h-[80vh] overflow-y-auto animate-scale-in">
        <div class="sticky top-0 bg-card/95 backdrop-blur-sm border-b border-white/10 p-6 flex items-center justify-between">
          <h2 id="achievements-title" class="text-2xl font-bold text-white flex items-center gap-3">
            <span class="text-3xl">🏆</span>
            <div>
              <span>Achievements</span>
              <span class="block text-sm font-normal text-gray-400"><span id="modal-achievement-progress">0</span>% complete</span>
            </div>
          </h2>
          <button id="close-achievements" class="p-2 text-gray-400 hover:text-white hover:bg-white/10 rounded-xl transition-colors" aria-label="Close achievements modal">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16"><path d="M4.646 4.646a.5.5 0 01.708 0L8 7.293l2.646-2.647a.5.5 0 01.708.708L8.707 8l2.647 2.646a.5.5 0 01-.708.708L8 8.707l-2.646 2.647a.5.5 0 01-.708-.708L7.293 8 4.646 5.354a.5.5 0 010-.708z"/></svg>
          </button>
        </div>
        <div class="p-6 space-y-6">
          <div>
            <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-4 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-green-500"></span>
              Unlocked
            </h3>
            <div id="unlocked-achievements" class="grid grid-cols-1 sm:grid-cols-2 gap-3"></div>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-4 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-gray-500"></span>
              Locked
            </h3>
            <div id="locked-achievements" class="grid grid-cols-1 sm:grid-cols-2 gap-3"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Slop Scores Modal -->
  <div id="slop-scores-modal" class="hidden fixed inset-0 z-50 overflow-y-auto" role="dialog" aria-modal="true" aria-labelledby="slop-scores-title">
    <div class="fixed inset-0 bg-black/80 backdrop-blur-sm transition-opacity animate-fade-in"></div>
    <div class="relative min-h-screen flex items-center justify-center p-4">
      <div class="relative bg-card rounded-3xl border border-white/10 shadow-2xl max-w-4xl w-full max-h-[80vh] overflow-y-auto animate-scale-in">
        <div class="sticky top-0 bg-card/95 backdrop-blur-sm border-b border-white/10 p-6 flex items-center justify-between">
          <h2 id="slop-scores-title" class="text-2xl font-bold text-white flex items-center gap-3">
            <span class="text-3xl">⭐</span>
            <div>
              <span>Slop Scores™</span>
              <span class="block text-sm font-normal text-gray-400">Scientifically calculated</span>
            </div>
          </h2>
          <button id="close-slop-scores" class="p-2 text-gray-400 hover:text-white hover:bg-white/10 rounded-xl transition-colors" aria-label="Close slop scores modal">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16"><path d="M4.646 4.646a.5.5 0 01.708 0L8 7.293l2.646-2.647a.5.5 0 01.708.708L8.707 8l2.647 2.646a.5.5 0 01-.708.708L8 8.707l-2.646 2.647a.5.5 0 01-.708-.708L7.293 8 4.646 5.354a.5.5 0 010-.708z"/></svg>
          </button>
        </div>
        <div class="p-6">
          <div id="slop-scores-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Repository Detail Modal -->
  <div id="repo-detail-modal" class="hidden fixed inset-0 z-50 overflow-y-auto" role="dialog" aria-modal="true" aria-labelledby="repo-detail-title">
    <div class="fixed inset-0 bg-black/80 backdrop-blur-sm transition-opacity animate-fade-in"></div>
    <div class="relative min-h-screen flex items-center justify-center p-4">
      <div class="relative bg-card rounded-3xl border border-white/10 shadow-2xl max-w-3xl w-full max-h-[80vh] overflow-y-auto animate-scale-in">
        <div class="sticky top-0 bg-card/95 backdrop-blur-sm border-b border-white/10 p-6 flex items-center justify-between">
          <h2 id="repo-detail-title" class="text-2xl font-bold text-white flex items-center gap-3">
            <span class="text-3xl">📦</span>
            <span id="modal-repo-name"></span>
          </h2>
          <button id="close-repo-detail" class="p-2 text-gray-400 hover:text-white hover:bg-white/10 rounded-xl transition-colors" aria-label="Close repository details">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16"><path d="M4.646 4.646a.5.5 0 01.708 0L8 7.293l2.646-2.647a.5.5 0 01.708.708L8.707 8l2.647 2.646a.5.5 0 01-.708.708L8 8.707l-2.646 2.647a.5.5 0 01-.708-.708L7.293 8 4.646 5.354a.5.5 0 010-.708z"/></svg>
          </button>
        </div>
        <div class="p-6 space-y-6">
          <!-- Description -->
          <div>
            <p id="modal-repo-description" class="text-gray-300 text-lg leading-relaxed"></p>
          </div>

          <!-- Topics -->
          <div id="modal-repo-topics" class="flex flex-wrap gap-2"></div>

          <!-- Stats Grid -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div class="p-4 bg-white/5 rounded-2xl border border-white/10">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-2xl">⭐</span>
                <span class="text-xs text-gray-400 uppercase tracking-wide">Stars</span>
              </div>
              <span id="modal-repo-stars" class="text-2xl font-bold text-yellow-400"></span>
            </div>
            <div class="p-4 bg-white/5 rounded-2xl border border-white/10">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-2xl">🍴</span>
                <span class="text-xs text-gray-400 uppercase tracking-wide">Forks</span>
              </div>
              <span id="modal-repo-forks" class="text-2xl font-bold text-blue-400"></span>
            </div>
            <div class="p-4 bg-white/5 rounded-2xl border border-white/10">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-2xl">💾</span>
                <span class="text-xs text-gray-400 uppercase tracking-wide">Language</span>
              </div>
              <span id="modal-repo-language" class="text-lg font-semibold text-purple-400"></span>
            </div>
            <div class="p-4 bg-white/5 rounded-2xl border border-white/10">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-2xl">🌿</span>
                <span class="text-xs text-gray-400 uppercase tracking-wide">Branch</span>
              </div>
              <span id="modal-repo-branch" class="text-lg font-semibold text-green-400"></span>
            </div>
          </div>

          <!-- Dates -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex items-center gap-3 p-3 bg-white/5 rounded-xl border border-white/10">
              <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 16 16"><path d="M8 3.5a.5.5 0 00-1 0V9a.5.5 0 00.252.434l3.5 2a.5.5 0 00.496-.868L8 8.71V3.5z"/><path d="M8 16A8 8 0 108 0a8 8 0 000 16zm7-8A7 7 0 111 8a7 7 0 0114 0z"/></svg>
              <div>
                <span class="text-xs text-gray-400 uppercase tracking-wide">Created</span>
                <p id="modal-repo-created" class="text-sm text-gray-300"></p>
              </div>
            </div>
            <div class="flex items-center gap-3 p-3 bg-white/5 rounded-xl border border-white/10">
              <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 16 16"><path d="M8 3.5a.5.5 0 00-1 0V9a.5.5 0 00.252.434l3.5 2a.5.5 0 00.496-.868L8 8.71V3.5z"/><path d="M8 16A8 8 0 108 0a8 8 0 000 16zm7-8A7 7 0 111 8a7 7 0 0114 0z"/></svg>
              <div>
                <span class="text-xs text-gray-400 uppercase tracking-wide">Updated</span>
                <p id="modal-repo-updated" class="text-sm text-gray-300"></p>
              </div>
            </div>
          </div>

          <!-- Homepage -->
          <div id="modal-repo-homepage-container" class="hidden flex items-center gap-3 p-3 bg-white/5 rounded-xl border border-white/10">
            <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 16 16"><path d="M8.707 1.5a1 1 0 00-1.414 0L.646 8.146a.5.5 0 00.708.708L2 8.207V13.5A1.5 1.5 0 003.5 15h9a1.5 1.5 0 001.5-1.5V8.207l.646.647a.5.5 0 00.708-.708L13 5.793V2.5a.5.5 0 00-.5-.5h-1a.5.5 0 00-.5.5v1.293L8.707 1.5ZM13 7.207V13.5a.5.5 0 01-.5.5h-9a.5.5 0 01-.5-.5V7.207l5-5 5 5Z"/></svg>
            <div>
              <span class="text-xs text-gray-400 uppercase tracking-wide">Homepage</span>
              <p><a id="modal-repo-homepage" href="#" target="_blank" rel="noopener noreferrer" class="text-purple-400 hover:text-purple-300 underline"></a></p>
            </div>
          </div>

          <!-- Archived Badge -->
          <div id="modal-repo-archived" class="hidden">
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-orange-500/20 text-orange-400 text-sm font-medium rounded-xl border border-orange-500/30">
              <span>📦</span> Archived
            </span>
          </div>

          <!-- Action Buttons -->
          <div class="flex flex-wrap gap-4 pt-4 border-t border-white/10">
            <a id="modal-repo-github" href="#" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 px-6 py-3 bg-white text-gray-900 font-semibold rounded-xl hover:bg-gray-200 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
              <span>View on GitHub</span>
            </a>
            <button id="modal-repo-close" class="px-6 py-3 bg-white/10 text-white font-semibold rounded-xl hover:bg-white/20 transition-colors">
              Close
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast Container -->
  <div id="toast-container" class="fixed bottom-6 right-6 z-50 flex flex-col gap-2"></div>
</body>
</html>
