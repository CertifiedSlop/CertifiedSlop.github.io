</head>
<body class="bg-primary text-white min-h-screen flex flex-col">
  <!-- Scroll Progress Bar -->
  <div id="scroll-progress" class="fixed top-0 left-0 h-1 bg-gradient-to-r from-purple-500 via-pink-500 to-blue-500 z-[10000] transition-all duration-150" style="width: 0%"></div>

  <!-- Achievement Notifications -->
