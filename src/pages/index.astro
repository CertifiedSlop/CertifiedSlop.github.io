            src="https://avatars.githubusercontent.com/u/265597819?v=4"
            alt="Certified Slop organization avatar"
            class="relative w-32 h-32 sm:w-40 sm:h-40 lg:w-48 lg:h-48 rounded-full border-2 border-white/20 shadow-2xl shadow-purple-500/20 animate-float transition-transform duration-500 group-hover:scale-105"
            width="192"
            height="192"
