        </div>

        <!-- Title & Tagline -->
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black mb-4 tracking-tight">
          <span class="bg-gradient-to-r from-purple-400 via-pink-400 to-blue-400 bg-clip-text text-transparent drop-shadow-lg">
